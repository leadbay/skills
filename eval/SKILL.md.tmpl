  "tokens_session_out": 0,
  "tokens_judge_in": 0,
  "tokens_judge_out": 0,
  "turns_used": 0,
  "tool_call_count": 0,
  "tool_call_breakdown": {},
  "shape_ratio": 0,
  "first_response_ms": 0,
  "max_inter_turn_ms": 0,
  "model": "claude-sonnet-4-6",
  "evidence": {
    "session": {
      "session_id": "RUN_ID-workflow-N",
      "prompt_name": "PROMPT_NAME",
