#!/usr/bin/env bash
# Quick update check — called from skill preambles.
# Compares local VERSION with remote. Prints notice if different.
# Caches result for 6 hours to avoid hitting GitHub on every run.

SKILLS_HOME="${HOME}/.leadbay-skills"
CACHE_FILE="${HOME}/.leadbay-skills/.update-cache"
CACHE_TTL=21600  # 6 hours

LOCAL_VERSION=$(cat "$SKILLS_HOME/VERSION" 2>/dev/null || echo "unknown")

# Check cache freshness
if [ -f "$CACHE_FILE" ]; then
  cache_age=$(( $(date +%s) - $(stat -f%m "$CACHE_FILE" 2>/dev/null || stat -c%Y "$CACHE_FILE" 2>/dev/null || echo 0) ))
  if [ "$cache_age" -lt "$CACHE_TTL" ]; then
    cached=$(cat "$CACHE_FILE")
    if [ "$cached" != "$LOCAL_VERSION" ] && [ "$cached" != "current" ]; then
      echo "UPGRADE_AVAILABLE $LOCAL_VERSION $cached"
    fi
    exit 0
  fi
fi

# Fetch remote version (fast, single file)
REMOTE_VERSION=$(gh api "repos/leadbay/skills/contents/VERSION" --jq '.content' 2>/dev/null | base64 -d 2>/dev/null | tr -d '[:space:]')

if [ -z "$REMOTE_VERSION" ]; then
  echo "current" > "$CACHE_FILE" 2>/dev/null
  exit 0
fi

echo "$REMOTE_VERSION" > "$CACHE_FILE" 2>/dev/null

if [ "$REMOTE_VERSION" != "$LOCAL_VERSION" ]; then
  echo "UPGRADE_AVAILABLE $LOCAL_VERSION $REMOTE_VERSION"
fi
