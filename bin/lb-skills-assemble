#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
HEADER="<!-- GENERATED by bin/lb-skills-assemble from SKILL.md.tmpl — DO NOT EDIT DIRECTLY -->"
count=0

for tmpl in "$REPO_ROOT"/*/SKILL.md.tmpl; do
  [ -f "$tmpl" ] || continue
  skill_dir="$(dirname "$tmpl")"
  skill_name="$(basename "$skill_dir")"
  output="$skill_dir/SKILL.md"
  includes=0

  {
    echo "$HEADER"
    while IFS= read -r line || [ -n "$line" ]; do
      if [[ "$line" =~ ^'<!-- include: '(shared/[a-zA-Z0-9._-]+\.md)' -->'$ ]]; then
        fragment="$REPO_ROOT/${BASH_REMATCH[1]}"
        if [ ! -f "$fragment" ]; then
          echo "ERROR: $skill_name/SKILL.md.tmpl references ${BASH_REMATCH[1]} but it does not exist" >&2
          exit 1
        fi
        cat "$fragment"
        ((includes++))
      else
        echo "$line"
      fi
    done < "$tmpl"
  } > "$output"

  echo "  Assembled $skill_name/SKILL.md ($includes includes)"
  ((count++))
done

echo ""
echo "Assembled $count skill(s)."
