#!/usr/bin/env bash
# lb-knowledge-find — pre-task retrieval brief for any agent run.
#
# Auto-invoked by the UserPromptSubmit hook (see setup --with-knowledge). Takes
# the user's prompt as argument(s) or stdin, and returns a focused brief from
# THREE sources:
#
#   1. Local learnings (~/.leadbay/projects/<slug>/learnings.jsonl) via lb-learnings-search
#   2. Consolidated wiki   (~/.leadbay/knowledge/wiki/**/*.md) by frontmatter title/aliases/backend_names
#   3. Recent unconsolidated journal (~/.leadbay/knowledge/journal/) — last 7 days,
#      tagged "unconsolidated" so the model knows to weight them less.
#
# It also reads ~/.leadbay/knowledge/glossary.md for alias expansion of product terms.
#
# Per-session dedup (added v0.6.0):
#   - Style pages (`type: style`) for the current repo are injected on the FIRST
#     prompt of a session and never again — once is enough; the model has them.
#   - Other wiki pages: first-hit-of-session emits the full body, subsequent hits
#     in the same session emit a one-line pointer ("see earlier brief").
#   - Session detection: prefer `session_id` from stdin JSON (Claude Code modern
#     hook contract). Falls back to a hash of cwd+PPID for older harnesses.
#
# Output is markdown, prefixed with a "## Knowledge brief" heading and ending with
# the standing-instructions block (see KNOWLEDGE_PROTOCOL_INSTRUCTIONS below).
# The hook prepends this to the user's actual prompt as system context.
#
# Usage:
#   lb-knowledge-find "<prompt text>"          # one shot
#   echo "<prompt>" | lb-knowledge-find        # via stdin (raw text or JSON)
#   lb-knowledge-find --quiet "<prompt>"       # suppress headers if no results

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
LEADBAY_HOME="${LEADBAY_HOME:-$HOME/.leadbay}"
KNOWLEDGE_DIR="$LEADBAY_HOME/knowledge"

QUIET=false
WIKI_LIMIT="${LB_FIND_WIKI_LIMIT:-3}"
JOURNAL_DAYS="${LB_FIND_JOURNAL_DAYS:-7}"
JOURNAL_LIMIT="${LB_FIND_JOURNAL_LIMIT:-5}"
LEARNINGS_LIMIT="${LB_FIND_LEARNINGS_LIMIT:-5}"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --quiet) QUIET=true; shift ;;
    --wiki-limit) WIKI_LIMIT="$2"; shift 2 ;;
    --journal-days) JOURNAL_DAYS="$2"; shift 2 ;;
    --journal-limit) JOURNAL_LIMIT="$2"; shift 2 ;;
    --learnings-limit) LEARNINGS_LIMIT="$2"; shift 2 ;;
    --) shift; break ;;
    -*) echo "lb-knowledge-find: unknown option $1" >&2; exit 2 ;;
    *) break ;;
  esac
done

PROMPT="${*:-}"
SESSION_ID=""
HOOK_CWD="$PWD"

# Detect input: argv > stdin JSON > stdin raw.
# Claude Code's modern hook contract delivers JSON on stdin like:
#   {"session_id":"...","cwd":"...","hook_event_name":"UserPromptSubmit","prompt":"..."}
# Older harnesses pass the prompt as argv only.
if [[ ! -t 0 ]]; then
  STDIN_RAW="$(cat 2>/dev/null || true)"
  if [[ -n "$STDIN_RAW" ]]; then
    if [[ "${STDIN_RAW:0:1}" == "{" ]]; then
      # JSON — extract session_id, cwd, prompt
      PARSED=$(LB_INPUT="$STDIN_RAW" python3 - <<'PY' 2>/dev/null || true
import os, json, sys
try:
    d = json.loads(os.environ["LB_INPUT"])
except Exception:
    sys.exit(0)
print(d.get("session_id", ""))
print(d.get("cwd", ""))
print(d.get("prompt", ""))
PY
)
      if [[ -n "$PARSED" ]]; then
        SESSION_ID=$(printf '%s\n' "$PARSED" | sed -n '1p')
        STDIN_CWD=$(printf '%s\n' "$PARSED" | sed -n '2p')
        STDIN_PROMPT=$(printf '%s\n' "$PARSED" | sed -n '3p')
        [[ -n "$STDIN_CWD" ]] && HOOK_CWD="$STDIN_CWD"
        [[ -z "$PROMPT" && -n "$STDIN_PROMPT" ]] && PROMPT="$STDIN_PROMPT"
      fi
    elif [[ -z "$PROMPT" ]]; then
      PROMPT="$STDIN_RAW"
    fi
  fi
fi

# Fallback session id when JSON didn't supply one. PPID is the parent process,
# which under Claude Code is the long-lived `claude` process — stable across
# hook calls within one session.
if [[ -z "$SESSION_ID" ]]; then
  SESSION_ID=$(printf '%s' "$HOOK_CWD-$PPID" | shasum 2>/dev/null | cut -c1-12 || echo "fallback")
fi

SESSION_DIR="${TMPDIR:-/tmp}/lb-knowledge-find/$SESSION_ID"
mkdir -p "$SESSION_DIR"

# Detect current repo for style-page targeting. Style pages are pinned on first
# call only when their `backend_names` frontmatter mentions the current repo.
CURRENT_REPO=""
if command -v git >/dev/null 2>&1; then
  REPO_URL=$(git -C "$HOOK_CWD" config --get remote.origin.url 2>/dev/null || true)
  if [[ -n "$REPO_URL" ]]; then
    # Strip .git, take last two path components → "owner/repo"
    CURRENT_REPO=$(printf '%s' "$REPO_URL" | sed -E 's#\.git$##; s#^.*[:/]([^/]+/[^/]+)$#\1#')
  fi
fi

# Strip newlines, lower-case for matching
NORMALIZED=$(printf '%s' "$PROMPT" | tr '\n' ' ' | tr '[:upper:]' '[:lower:]')

# --- 1. Local learnings ---
LEARNINGS_OUT=""
if [[ -x "$SCRIPT_DIR/lb-learnings-search" ]]; then
  KEYWORD=$(printf '%s' "$NORMALIZED" | tr -cd 'a-z0-9 \-_' | awk '{for(i=1;i<=NF;i++) if (length($i)>=4) {print $i; exit}}')
  if [[ -n "$KEYWORD" ]]; then
    LEARNINGS_OUT=$("$SCRIPT_DIR/lb-learnings-search" --query "$KEYWORD" --limit "$LEARNINGS_LIMIT" 2>/dev/null || true)
  else
    LEARNINGS_OUT=$("$SCRIPT_DIR/lb-learnings-search" --limit "$LEARNINGS_LIMIT" 2>/dev/null || true)
  fi
fi

# --- 2. Consolidated wiki (with session-aware dedup) ---
WIKI_OUT=""
STYLE_OUT=""
WIKI_DIR="$KNOWLEDGE_DIR/wiki"
if [[ -d "$WIKI_DIR" ]]; then
  WIKI_AND_STYLE=$(LB_NORMALIZED="$NORMALIZED" \
                   LB_WIKI_DIR="$WIKI_DIR" \
                   LB_WIKI_LIMIT="$WIKI_LIMIT" \
                   LB_SESSION_DIR="$SESSION_DIR" \
                   LB_CURRENT_REPO="$CURRENT_REPO" \
                   python3 - <<'PY'
import os, pathlib, re, sys
norm = os.environ["LB_NORMALIZED"]
root = pathlib.Path(os.environ["LB_WIKI_DIR"])
limit = int(os.environ["LB_WIKI_LIMIT"])
session_dir = pathlib.Path(os.environ["LB_SESSION_DIR"])
current_repo = os.environ["LB_CURRENT_REPO"].lower()

DOMAIN_SHORT_OK = {"lens", "lead", "wow", "chat", "tab"}
STOPWORDS = {"the", "and", "for", "with", "from", "this", "that", "what", "when", "where", "how", "why", "are", "was", "were", "but", "not", "you", "your", "have", "has", "had", "can", "did", "does", "into", "out", "any"}
tokens = set()
for t in re.findall(r"[a-z0-9][a-z0-9_-]+", norm):
    if t in STOPWORDS:
        continue
    if len(t) >= 4 or t in DOMAIN_SHORT_OK:
        tokens.add(t)

def parse_frontmatter(text):
    if not text.startswith("---"):
        return None, ""
    end = text.find("\n---", 4)
    if end < 0:
        return None, ""
    fm = {}
    for line in text[4:end].splitlines():
        if ":" not in line:
            continue
        k, _, v = line.partition(":")
        fm[k.strip()] = v.strip()
        # Crude — only captures single-line values; fine for the fields we score.
    return fm, text[end+4:]

def slug(p):
    return str(p.relative_to(root.parent)).replace("/", "_").replace(".md", "")

style_hits = []      # [(p, text)]
wiki_hits = []       # [(score, p, text)]
field_weight = {"title": 5, "aliases": 4, "backend_names": 3, "ui_locations": 2}

for p in root.rglob("*.md"):
    try:
        text = p.read_text()
    except Exception:
        continue
    if not text.startswith("---"):
        continue
    end = text.find("\n---", 4)
    if end < 0:
        continue
    fm_raw = text[4:end]

    # Detect type=style and backend_names match for current repo
    is_style = False
    matches_repo = False
    in_backend_names = False
    for line in fm_raw.splitlines():
        ls = line.strip()
        if ls.startswith("type:") and "style" in ls:
            is_style = True
        if ls.startswith("backend_names:"):
            in_backend_names = True
            v = ls.split(":", 1)[1].strip()
            if v.startswith("[") and current_repo and current_repo in v.lower():
                matches_repo = True
        elif in_backend_names and ls.startswith("- "):
            v = ls[2:].strip().lower()
            if current_repo and current_repo in v:
                matches_repo = True
        elif in_backend_names and not ls.startswith("- ") and ls and not ls.startswith("#"):
            in_backend_names = False

    if is_style and matches_repo:
        style_hits.append((p, text))
        continue  # style pages don't get scored against the prompt — they're always-on for the repo

    # Score non-style pages by frontmatter token hits
    score = 0
    for line in fm_raw.splitlines():
        if ":" not in line:
            continue
        k, _, v = line.partition(":")
        k = k.strip()
        if k not in field_weight:
            continue
        v_norm = v.lower()
        for t in tokens:
            if t in v_norm:
                score += field_weight[k]
    if score > 0:
        wiki_hits.append((score, p, text))

wiki_hits.sort(key=lambda x: -x[0])

# Style block — emit only on first prompt of session
style_flag = session_dir / "_styles_injected.flag"
style_out_lines = []
if style_hits and not style_flag.exists():
    for p, text in style_hits:
        rel = p.relative_to(root.parent)
        style_out_lines.append(f"### {rel} (repo style — injected once per session)\n\n{text}")
    style_flag.touch()
elif style_hits:
    rels = ", ".join(str(p.relative_to(root.parent)) for p, _ in style_hits)
    style_out_lines.append(f"_Repo style pages already in this session's context: {rels}_")

# Non-style wiki: full body on first hit per session, pointer on subsequent
wiki_out_lines = []
for score, p, text in wiki_hits[:limit]:
    rel = p.relative_to(root.parent)
    marker = session_dir / f"page-{slug(p)}.seen"
    if marker.exists():
        wiki_out_lines.append(f"_Already in this session's context: {rel} (relevance={score})_")
    else:
        wiki_out_lines.append(f"### {rel} (relevance={score})\n\n{text}")
        marker.touch()

# Output style block first, then \n\n---WIKI---\n\n separator, then wiki block
print("\n\n".join(style_out_lines))
print("---WIKI---")
print("\n\n---\n\n".join(wiki_out_lines))
PY
)
  STYLE_OUT="${WIKI_AND_STYLE%%---WIKI---*}"
  WIKI_OUT="${WIKI_AND_STYLE#*---WIKI---}"
  STYLE_OUT="${STYLE_OUT%$'\n'}"
  WIKI_OUT="${WIKI_OUT#$'\n'}"
fi

# --- 3. Recent unconsolidated journal entries ---
JOURNAL_OUT=""
JOURNAL_DIR="$KNOWLEDGE_DIR/journal"
if [[ -d "$JOURNAL_DIR" ]]; then
  JOURNAL_OUT=$(LB_NORMALIZED="$NORMALIZED" LB_JOURNAL_DIR="$JOURNAL_DIR" LB_JOURNAL_DAYS="$JOURNAL_DAYS" LB_JOURNAL_LIMIT="$JOURNAL_LIMIT" LB_SESSION_DIR="$SESSION_DIR" python3 - <<'PY'
import os, pathlib, re, time, sys
norm = os.environ["LB_NORMALIZED"]
root = pathlib.Path(os.environ["LB_JOURNAL_DIR"])
days = int(os.environ["LB_JOURNAL_DAYS"])
limit = int(os.environ["LB_JOURNAL_LIMIT"])
session_dir = pathlib.Path(os.environ["LB_SESSION_DIR"])

DOMAIN_SHORT_OK = {"lens", "lead", "wow", "chat", "tab"}
STOPWORDS = {"the", "and", "for", "with", "from", "this", "that", "what", "when", "where", "how", "why", "are", "was", "were", "but", "not", "you", "your", "have", "has", "had", "can", "did", "does", "into", "out", "any"}
tokens = set()
for t in re.findall(r"[a-z0-9][a-z0-9_-]+", norm):
    if t in STOPWORDS:
        continue
    if len(t) >= 4 or t in DOMAIN_SHORT_OK:
        tokens.add(t)
cutoff = time.time() - days*86400
hits = []
for p in root.rglob("*.md"):
    try:
        if p.stat().st_mtime < cutoff:
            continue
        text = p.read_text()
    except Exception:
        continue
    body_norm = text.lower()
    score = sum(1 for t in tokens if t in body_norm)
    if score > 0:
        hits.append((score, p.stat().st_mtime, p, text))
hits.sort(key=lambda x: (-x[0], -x[1]))
out = []
for score, mtime, p, text in hits[:limit]:
    rel = p.relative_to(root.parent)
    slug = str(rel).replace("/", "_").replace(".md", "")
    marker = session_dir / f"journal-{slug}.seen"
    if marker.exists():
        out.append(f"_Already in this session's context: {rel} [unconsolidated, score={score}]_")
    else:
        out.append(f"### {rel} [unconsolidated, score={score}]\n\n{text}")
        marker.touch()
print("\n\n---\n\n".join(out))
PY
  ) || JOURNAL_OUT=""
fi

# --- 4. Glossary alias expansion (informational only) ---
GLOSSARY_OUT=""
GLOSSARY_FILE="$KNOWLEDGE_DIR/glossary.md"
if [[ -f "$GLOSSARY_FILE" ]]; then
  GLOSSARY_OUT=$(LB_NORMALIZED="$NORMALIZED" LB_GLOSSARY="$GLOSSARY_FILE" python3 - <<'PY'
# Strict glossary match: a row only counts if a prompt token matches the
# Term cell (the first column) — not any cell.
import os, re
norm = os.environ["LB_NORMALIZED"]
fp = os.environ["LB_GLOSSARY"]
DOMAIN_SHORT_OK = {"lens", "lead", "wow", "chat", "tab"}
tokens = set()
for t in re.findall(r"[a-z0-9][a-z0-9_-]{1,}", norm):
    if len(t) >= 4 or t in DOMAIN_SHORT_OK:
        tokens.add(t)
hits = []
try:
    txt = open(fp).read()
except Exception:
    raise SystemExit
seen_pages = set()
for line in txt.splitlines():
    if not line.startswith("|") or "----" in line or line.strip().startswith("| Term"):
        continue
    cells = [c.strip() for c in line.strip("|").split("|")]
    if len(cells) < 5:
        continue
    term = cells[0].lower()
    page_link = cells[4]
    if not any(t in term for t in tokens):
        continue
    if page_link in seen_pages:
        continue
    seen_pages.add(page_link)
    hits.append(line)
    if len(hits) >= 8:
        break
if hits:
    print("\n".join(hits))
PY
  ) || GLOSSARY_OUT=""
fi

# Standing instructions injected on every brief
read -r -d '' KNOWLEDGE_PROTOCOL_INSTRUCTIONS <<'EOF' || true

## Standing instructions (knowledge protocol)

- If during this task you hit an architectural ambiguity, an unfamiliar
  product concept, or contradictory information that the brief above
  doesn't resolve — invoke `/knowledge-question` rather than guessing.
- If the user is asking you to learn, document, or explore a new product
  surface (a UI tab, a backend service, a user journey) — invoke
  `/knowledge-explore` rather than starting to code immediately.
- If you find yourself about to write more than ~20 lines of code in an
  area no journal entry or wiki page covers, pause and invoke
  `/knowledge-question` with what you'd be guessing at.
- Treat unconsolidated journal entries (tagged above) as *recent observations*,
  not canonical truth — they outrank stale wiki pages but the dream consolidator
  may still revise them.
- If the current repo has no `wiki/style/<repo>.md` and you're about to write
  non-trivial code, invoke `/distill-style` first to extract the dominant
  reviewer's convictions from PR history.
EOF

# Emit the brief
HAS_CONTENT=false
[[ -n "$LEARNINGS_OUT$WIKI_OUT$STYLE_OUT$JOURNAL_OUT$GLOSSARY_OUT" ]] && HAS_CONTENT=true

if [[ "$QUIET" == "true" && "$HAS_CONTENT" == "false" ]]; then
  exit 0
fi

echo "## Knowledge brief"
echo ""
echo "_Prepended automatically by the \`UserPromptSubmit\` hook from \`~/.leadbay/knowledge\` and local learnings._"
echo ""

if [[ -n "$STYLE_OUT" ]]; then
  echo "### Repo coding style"
  echo ""
  echo "$STYLE_OUT"
  echo ""
fi

if [[ -n "$GLOSSARY_OUT" ]]; then
  echo "### Glossary hits"
  echo ""
  echo "$GLOSSARY_OUT"
  echo ""
fi

if [[ -n "$WIKI_OUT" ]]; then
  echo "### Wiki pages"
  echo ""
  echo "$WIKI_OUT"
  echo ""
fi

if [[ -n "$JOURNAL_OUT" ]]; then
  echo "### Recent journal entries (unconsolidated)"
  echo ""
  echo "$JOURNAL_OUT"
  echo ""
fi

if [[ -n "$LEARNINGS_OUT" ]]; then
  echo "### Local learnings (this project)"
  echo ""
  echo "$LEARNINGS_OUT"
  echo ""
fi

if [[ "$HAS_CONTENT" == "false" ]]; then
  echo "_No matching wiki pages, journal entries, or learnings. The wiki may not yet cover this topic._"
  echo ""
  echo "_Recommend running \`/knowledge-explore\` to seed it from the live app + code._"
  echo ""
fi

echo "$KNOWLEDGE_PROTOCOL_INSTRUCTIONS"
