#!/usr/bin/env bash
# lb-knowledge-glossary — resolve a product term to canonical name + backend entities.
#
# Reads ~/.leadbay/knowledge/wiki/**/*.md frontmatter (title, aliases,
# backend_names, ui_locations) and returns the matching entry as JSON.
#
# Usage:
#   lb-knowledge-glossary "<term>"
#   echo "<term>" | lb-knowledge-glossary
#
# Output: JSON object on stdout, or empty + exit 1 if no match.

set -euo pipefail

LEADBAY_HOME="${LEADBAY_HOME:-$HOME/.leadbay}"
WIKI_DIR="$LEADBAY_HOME/knowledge/wiki"

if [[ ! -d "$WIKI_DIR" ]]; then
  exit 1
fi

TERM="${1:-}"
[[ -z "$TERM" && ! -t 0 ]] && TERM="$(cat)"
[[ -z "$TERM" ]] && { echo "Usage: lb-knowledge-glossary <term>" >&2; exit 2; }

LB_TERM="$TERM" LB_WIKI_DIR="$WIKI_DIR" python3 - <<'PY'
import json, os, pathlib, re
term = os.environ["LB_TERM"].strip().lower()
root = pathlib.Path(os.environ["LB_WIKI_DIR"])
best = None
best_score = 0
for p in root.rglob("*.md"):
    try:
        text = p.read_text()
    except Exception:
        continue
    if not text.startswith("---"):
        continue
    end = text.find("\n---", 4)
    if end < 0:
        continue
    fm = {}
    cur_list = None
    for line in text[4:end].splitlines():
        if not line.strip():
            cur_list = None
            continue
        if line.startswith("- "):
            if cur_list:
                fm.setdefault(cur_list, []).append(line[2:].strip().strip("'\""))
            continue
        cur_list = None
        if ":" not in line:
            continue
        k, _, v = line.partition(":")
        k = k.strip(); v = v.strip()
        if v == "":
            cur_list = k
            fm[k] = []
        elif v.startswith("[") and v.endswith("]"):
            inner = v[1:-1].strip()
            fm[k] = [x.strip().strip("'\"") for x in inner.split(",") if x.strip()]
        else:
            fm[k] = v.strip("'\"")
    score = 0
    title = (fm.get("title") or "").lower()
    aliases = [a.lower() for a in (fm.get("aliases") or [])]
    backend = [b.lower() for b in (fm.get("backend_names") or [])]
    ui = [u.lower() for u in (fm.get("ui_locations") or [])]
    if title == term: score += 100
    if term in title: score += 30
    if term in aliases: score += 80
    if any(term in a for a in aliases): score += 20
    if term in backend: score += 50
    if any(term in b for b in backend): score += 15
    if any(term in u for u in ui): score += 10
    if score > best_score:
        best_score = score
        best = {
            "page": str(p.relative_to(root.parent)),
            "title": fm.get("title"),
            "type": fm.get("type"),
            "aliases": fm.get("aliases", []),
            "backend_names": fm.get("backend_names", []),
            "ui_locations": fm.get("ui_locations", []),
            "score": score,
        }
if best is None:
    raise SystemExit(1)
print(json.dumps(best, indent=2))
PY
