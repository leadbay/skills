#!/usr/bin/env bash
# lb-knowledge-explore — bootstrap orchestrator for product surfaces.
#
# Two modes (per spec §4.5, §9):
#
#   --mode code-only        Read OpenAPI specs, route maps, DB schemas, recent
#                           commits in the current repo. File concept/, mapping/,
#                           journey/ proposals with low confidence.
#
#   --mode pairing          Human-paired exploration. Prompts the developer to
#                           narrate a UI surface; if the Chrome MCP is wired up,
#                           also reads the live DOM. Drafts higher-confidence
#                           proposals + a sources/app-tours/ artifact.
#                           NEVER handles credentials. Attaches to the
#                           developer's already-authenticated browser session.
#
# This is a thin orchestrator — it doesn't talk to Claude itself. The actual
# /knowledge-explore SKILL drives the orchestration via prompts; this binary
# does the file-IO scaffolding (creating the proposed/ + sources/ entries,
# scanning code on demand, validating each write).
#
# Usage:
#   lb-knowledge-explore --mode code-only [--repo .]
#   lb-knowledge-explore --mode pairing --topic discover
#   lb-knowledge-explore scan-routes        # subcommand, prints route → handler map
#   lb-knowledge-explore scan-openapi <path>
#   lb-knowledge-explore scan-db-schema     # introspects current DATABASE_URL_RO
#   lb-knowledge-explore propose --concept <name> --type <t> --title <"..."> < body

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
LEADBAY_HOME="${LEADBAY_HOME:-$HOME/.leadbay}"

MODE=""
REPO="."
TOPIC=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --mode) MODE="$2"; shift 2 ;;
    --repo) REPO="$2"; shift 2 ;;
    --topic) TOPIC="$2"; shift 2 ;;
    --) shift; break ;;
    -*) break ;;
    *) break ;;
  esac
done

# Subcommand mode (no --mode flag): scan-routes / scan-openapi / scan-db-schema / propose
if [[ -z "$MODE" && $# -gt 0 ]]; then
  CMD="$1"; shift
  case "$CMD" in

    scan-routes)
      # Best-effort multi-language route scanner. Outputs `METHOD path` one per line.
      # Portable across BSD (macOS) and GNU (Linux) — uses python instead of sed.
      cd "$REPO"
      LB_REPO="$(pwd)" python3 - <<'PY'
import os, pathlib, re
repo = pathlib.Path(os.environ["LB_REPO"])
methods = "|".join(["get","post","put","delete","patch"])

patterns = [
    # FastAPI / Starlette: @app.get("/x") or @router.post("/y")
    (re.compile(rf'@(?:app|router)\.({methods})\(\s*[\'"]([^\'"]+)[\'"]'), "{0} {1}", "*.py"),
    # Express: app.get("/x", handler) or router.post("/y", ...)
    (re.compile(rf'\b(?:app|router)\.({methods})\(\s*[\'"]([^\'"]+)[\'"]'), "{0} {1}", ("*.js","*.ts","*.tsx","*.mjs","*.cjs")),
    # Flask: @app.route("/x", methods=["GET","POST"])
    (re.compile(r'@app\.route\(\s*[\'"]([^\'"]+)[\'"]'), "GET {0}", "*.py"),
    # Spring (Kotlin / Java): @GetMapping("/x"), @PostMapping("/y"), …
    (re.compile(r'@(Get|Post|Put|Delete|Patch)Mapping\(\s*[\'"]([^\'"]+)[\'"]'),
     "{0} {1}", ("*.kt","*.java")),
    # Ktor: routing { get("/x") { … } } / post("/y") { … }
    (re.compile(rf'\b({methods})\(\s*[\'"]([^\'"]+)[\'"]\s*\)\s*\{{'), "{0} {1}", ("*.kt",)),
    # Rails: get '/x', to: '...' (basic — covers many but not nested resources)
    (re.compile(rf"^\s*({methods})\s+[\'\"]([^\'\"]+)[\'\"]"), "{0} {1}", "*.rb"),
]

results = set()
for pat, fmt, glob in patterns:
    globs = (glob,) if isinstance(glob, str) else glob
    for g in globs:
        for path in repo.rglob(g):
            # Skip node_modules / vendor / build / .git noise
            if any(skip in path.parts for skip in ("node_modules", ".git", "build", "dist", "target", "vendor")):
                continue
            try:
                text = path.read_text(errors="replace")
            except Exception:
                continue
            for m in pat.finditer(text):
                method = m.group(1).upper()
                rest = m.group(2) if m.lastindex and m.lastindex >= 2 else ""
                line = fmt.format(method, rest).strip()
                results.add(line)

for line in sorted(results):
    print(line)
PY
      ;;

    scan-openapi)
      OAS_PATH="${1:-}"
      if [[ -z "$OAS_PATH" ]]; then
        # Look in conventional places
        for c in openapi.yaml openapi.yml openapi.json api.yaml api.yml api.json docs/openapi.yaml; do
          [[ -f "$REPO/$c" ]] && OAS_PATH="$REPO/$c" && break
        done
      fi
      [[ -z "$OAS_PATH" || ! -f "$OAS_PATH" ]] && { echo "lb-knowledge-explore scan-openapi: no spec found" >&2; exit 1; }
      LB_OAS="$OAS_PATH" python3 - <<'PY'
import json, os, sys, pathlib
p = pathlib.Path(os.environ["LB_OAS"])
data = None
try:
    if p.suffix in (".yaml", ".yml"):
        import yaml  # type: ignore
        data = yaml.safe_load(p.read_text())
    else:
        data = json.loads(p.read_text())
except Exception as e:
    print(f"failed to parse {p}: {e}", file=sys.stderr); sys.exit(1)
if not isinstance(data, dict) or "paths" not in data:
    print("not a valid OpenAPI document (missing paths)", file=sys.stderr); sys.exit(1)
for path, ops in (data.get("paths") or {}).items():
    if not isinstance(ops, dict):
        continue
    for method, op in ops.items():
        if method.lower() not in ("get","post","put","delete","patch"):
            continue
        summary = (op or {}).get("summary", "") if isinstance(op, dict) else ""
        print(f"{method.upper()} {path}\t{summary}")
PY
      ;;

    scan-db-schema)
      # Tries DATABASE_URL_PROD_RO first, then DATABASE_URL, then $1.
      DB_URL="${1:-${DATABASE_URL_PROD_RO:-${DATABASE_URL:-}}}"
      if [[ -z "$DB_URL" ]]; then
        echo "lb-knowledge-explore scan-db-schema: set DATABASE_URL_PROD_RO or pass URL" >&2
        exit 2
      fi
      if ! command -v psql >/dev/null 2>&1; then
        echo "lb-knowledge-explore scan-db-schema: psql not installed" >&2
        exit 2
      fi
      psql "$DB_URL" -At -c "
        SELECT table_schema || '.' || table_name AS qual,
               array_to_string(array_agg(column_name ORDER BY ordinal_position), ', ') AS cols
        FROM information_schema.columns
        WHERE table_schema NOT IN ('pg_catalog', 'information_schema')
        GROUP BY 1
        ORDER BY 1
      " 2>/dev/null
      ;;

    propose)
      # Pass-through to lb-knowledge-write proposed
      exec "$SCRIPT_DIR/lb-knowledge-write" proposed "$@"
      ;;

    *) echo "Unknown subcommand: $CMD" >&2; exit 2 ;;
  esac
  exit 0
fi

# --mode dispatch (orchestration helpers — the SKILL drives the rest)
case "$MODE" in
  code-only)
    cd "$REPO"
    REPO_NAME=$(basename "$(pwd)")
    echo "[lb-knowledge-explore] code-only sweep on $REPO_NAME"
    echo ""
    echo "## Routes"
    "$SCRIPT_DIR/lb-knowledge-explore" scan-routes 2>/dev/null | head -50 || true
    echo ""
    echo "## OpenAPI summary"
    "$SCRIPT_DIR/lb-knowledge-explore" scan-openapi 2>/dev/null | head -50 || true
    echo ""
    echo "## DB schema"
    "$SCRIPT_DIR/lb-knowledge-explore" scan-db-schema 2>/dev/null | head -50 || true
    echo ""
    echo "Now invoke /knowledge-explore (skill) to file proposed/ entries from the above."
    ;;
  pairing)
    [[ -z "$TOPIC" ]] && { echo "lb-knowledge-explore --mode pairing requires --topic" >&2; exit 2; }
    echo "[lb-knowledge-explore] pairing mode for topic: $TOPIC"
    echo ""
    echo "Skill workflow:"
    echo "  1. Open the live app in your already-logged-in browser."
    echo "  2. Navigate to the relevant screen for '$TOPIC'."
    echo "  3. The skill will read the live DOM via Chrome MCP (if connected)"
    echo "     OR ask you to narrate what's visible."
    echo "  4. Cross-references frontend route → API endpoint → DB schema."
    echo "  5. Files concept/, mapping/, journey/ proposals + a sources/app-tours/"
    echo "     artifact via lb-knowledge-write."
    echo ""
    echo "Credentials never appear in the agent prompt. The agent attaches to"
    echo "your existing browser session — it does not log in."
    ;;
  *)
    echo "Usage: lb-knowledge-explore --mode {code-only|pairing} [--topic <topic>] [--repo <path>]" >&2
    echo "       lb-knowledge-explore [scan-routes|scan-openapi|scan-db-schema|propose] [args...]" >&2
    exit 2
    ;;
esac
