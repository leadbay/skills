#!/usr/bin/env python3
"""
lb-knowledge-secret-scan — scan stdin for secret-shaped tokens.

Used by lb-knowledge-sync as a pre-write defence layer. The patterns
mirror leadbay/knowledge:bin/lb-knowledge-validate-all's SECRET_PATTERNS.
If they drift, the per-file validator (called by lb-knowledge-write)
will still catch missed patterns and the post-commit re-validate pass
catches anything that slips past both.

Exit 0 if clean, 1 if any pattern matches. Patterns matched are written
to stderr.
"""
import re
import sys

SECRET_PATTERNS = [
    re.compile(r"\b(sk|pk|rk)[-_][A-Za-z0-9]{16,}\b"),
    re.compile(r"\bsk-ant-[A-Za-z0-9_-]{20,}\b"),
    re.compile(r"\bsk-proj-[A-Za-z0-9_-]{20,}\b"),
    re.compile(r"\bgh[pousr]_[A-Za-z0-9]{36,}\b"),
    re.compile(r"\bgithub_pat_[A-Za-z0-9_]{40,}\b"),
    re.compile(r"\bAKIA[0-9A-Z]{16}\b"),
    re.compile(r"\beyJ[A-Za-z0-9_=-]{20,}\.[A-Za-z0-9_=-]{20,}\.[A-Za-z0-9_=-]{20,}\b"),
    re.compile(r"(?i)Authorization:\s*Bearer\s+[A-Za-z0-9._=-]{20,}"),
    re.compile(r"(?i)\b(?:password|passwd|secret)\s*[:=]\s*['\"]?[^\s'\"]{6,}"),
    re.compile(r"\bxox[abprs]-[A-Za-z0-9-]{10,}\b"),
]


def main() -> int:
    text = sys.stdin.read()
    for pat in SECRET_PATTERNS:
        m = pat.search(text)
        if m:
            sys.stderr.write(
                f"SECRET_DETECTED: /{pat.pattern[:60]}/ matched: {m.group(0)[:30]}\n"
            )
            return 1
    return 0


if __name__ == "__main__":
    sys.exit(main())
