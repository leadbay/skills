#!/usr/bin/env bash
# lb-knowledge-capture — Stop-hook entry point.
#
# When the model is engaged, /knowledge-capture as a skill drives schema-validated
# writes via lb-knowledge-write. This binary is the post-session safety net:
#
#   - Logs a session-end timeline event to ~/.leadbay/projects/<slug>/timeline.jsonl.
#   - Optionally fires the Layer-2 retrospective question filer (heuristics over
#     the session reasoning trail, if available).
#   - Optionally triggers a local sync (--push) so journal entries land before
#     the next periodic timer.
#
# Usage:
#   lb-knowledge-capture                 # full path: timeline + retro
#   lb-knowledge-capture --auto          # Stop-hook idempotent mode
#   lb-knowledge-capture --no-retro
#   lb-knowledge-capture --push          # also fire lb-knowledge-sync at end

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
LEADBAY_HOME="${LEADBAY_HOME:-$HOME/.leadbay}"

AUTO=false
DO_RETRO=true
DO_PUSH=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    --auto) AUTO=true; shift ;;
    --no-retro) DO_RETRO=false; shift ;;
    --push) DO_PUSH=true; shift ;;
    -*) shift ;;  # silently ignore unknown flags in --auto context to keep the hook robust
    *) break ;;
  esac
done

# Timeline event
if [[ -x "$SCRIPT_DIR/lb-timeline-log" ]]; then
  BRANCH=""
  if eval "$("$SCRIPT_DIR/lb-slug" 2>/dev/null)" 2>/dev/null; then
    :
  fi
  "$SCRIPT_DIR/lb-timeline-log" \
    "{\"skill\":\"_session\",\"event\":\"completed\",\"branch\":\"${BRANCH:-unknown}\"}" 2>/dev/null || true
fi

# Retrospective question filer (Layer 2)
if [[ "$DO_RETRO" == "true" ]]; then
  TRAIL="${LB_RETRO_TRAIL:-}"
  if [[ -n "$TRAIL" && -f "$TRAIL" && -x "$SCRIPT_DIR/lb-knowledge-sync" ]]; then
    LB_RETRO_TRAIL="$TRAIL" "$SCRIPT_DIR/lb-knowledge-sync" --no-push --no-retro 2>/dev/null || true
  fi
fi

# Optional sync (deferred to timer by default)
if [[ "$DO_PUSH" == "true" && -x "$SCRIPT_DIR/lb-knowledge-sync" ]]; then
  "$SCRIPT_DIR/lb-knowledge-sync" --no-retro 2>&1 | tail -5 || true
fi

exit 0
