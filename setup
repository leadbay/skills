#!/usr/bin/env bash
set -euo pipefail

SKILLS_HOME="${HOME}/.leadbay-skills"
CLAUDE_SKILLS="${HOME}/.claude/skills"

# If running --update, pull latest
if [ "${1:-}" = "--update" ]; then
  echo "Updating leadbay-skills..."
  cd "$SKILLS_HOME"
  git pull --rebase origin main
  echo "Updated to $(cat VERSION)"
fi

# Ensure claude skills dir exists
mkdir -p "$CLAUDE_SKILLS"

# Symlink each skill directory (skip bin, .git, etc.)
for skill_dir in "$SKILLS_HOME"/*/; do
  skill_name=$(basename "$skill_dir")
  # Skip non-skill directories
  case "$skill_name" in
    bin|.git|.github) continue ;;
  esac
  # Only link if it has a SKILL.md
  if [ -f "$skill_dir/SKILL.md" ]; then
    target="$CLAUDE_SKILLS/$skill_name"
    if [ -L "$target" ]; then
      rm "$target"
    elif [ -d "$target" ]; then
      echo "WARN: $target exists and is not a symlink, skipping"
      continue
    fi
    ln -s "$skill_dir" "$target"
    echo "  Linked /$skill_name"
  fi
done

echo ""
echo "Leadbay skills v$(cat "$SKILLS_HOME/VERSION") installed."
echo "Available commands: $(find "$SKILLS_HOME" -name SKILL.md -exec dirname {} \; | xargs -I{} basename {} | sort | sed 's/^/\//' | tr '\n' ' ')"
echo ""
echo "Update anytime: ~/.leadbay-skills/setup --update"
